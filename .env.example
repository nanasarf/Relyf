# Database Configuration
# ======================
# For local development, these are configured in appsettings.Development.json
# For production (Render, Azure, etc.), set these as environment variables

# SQL Server connection strings (use the same value for both)
# Format: Server=tcp:your-server.database.windows.net,1433;Initial Catalog=RelyfDb;User ID=username;Password=password;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;
ConnectionStrings__Default=YOUR_CLOUD_SQL_SERVER_CONNECTION_STRING_HERE
ConnectionStrings__RelyfDb=YOUR_CLOUD_SQL_SERVER_CONNECTION_STRING_HERE

# JWT Authentication
# ===================
# Generate a secure 64-byte Base64 key:
# PowerShell: [Convert]::ToBase64String((1..64 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
# Bash: openssl rand -base64 64
Jwt__Key=YOUR_BASE64_ENCODED_64_BYTE_SECRET_HERE
Jwt__Issuer=Relyf
Jwt__Audience=Relyf.Client
Jwt__AccessTokenMinutes=60

# Cohere AI Configuration
# =======================
# Get your API key from: https://dashboard.cohere.com/api-keys
Cohere__ApiKey=YOUR_COHERE_API_KEY_HERE
Cohere__BaseUrl=https://api.cohere.com
Cohere__Model=command-r-plus
Cohere__MaxTokens=400
Cohere__Temperature=0.2

# CORS Configuration (Optional)
# ==============================
# Additional origins can be added via environment variables
# Default origins are configured in appsettings.json
# To add more, use array syntax: Cors__AllowedOrigins__4=https://example.com

# Render Deployment Notes
# =======================
# 1. Go to Render Dashboard → Your Service → Environment
# 2. Add each variable above with actual values
# 3. Do NOT include quotes around values in Render UI
# 4. Click "Save Changes" - Render will auto-redeploy
# 5. Check logs for any configuration errors

# Azure SQL Database Example
# ===========================
# ConnectionStrings__Default=Server=tcp:relyf-db.database.windows.net,1433;Initial Catalog=RelyfDb;User ID=relyfadmin;Password=YourSecurePassword123!;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;
# ConnectionStrings__RelyfDb=Server=tcp:relyf-db.database.windows.net,1433;Initial Catalog=RelyfDb;User ID=relyfadmin;Password=YourSecurePassword123!;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;
