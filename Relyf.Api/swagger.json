          },
          "ownerId": {
            "type": "integer",
            "description": "ID of the owner entity"
          },
          "source": {
            "type": "string",
            "nullable": true,
            "description": "Can be: 'upload', 'url', 'cloudinary', or a base64 data URL"
          },
          "url": {
            "type": "string",
            "nullable": true,
            "description": "External URL or will be generated for uploads"
          },
          "altText": {
            "type": "string",
            "nullable": true,
            "description": "Alternative text for accessibility"
          }
        }
      },
      "ImageRecord": {
        "type": "object",
        "properties": {
          "imageId": {
            "type": "integer"
          },
          "ownerType": {
            "type": "string"
          },
          "ownerId": {
            "type": "integer"
          },
          "source": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "altText": {
            "type": "string",
            "nullable": true
          },
          "createdAtUtc": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "scheme": "bearer",
